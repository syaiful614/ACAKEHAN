# ============================================================
#  .env.example — Template environment Acakehan FastAPI
#  Salin ke ".env" lalu sesuaikan nilainya.
#  JANGAN commit file .env asli ke Git!
# ============================================================

# ── Identitas Aplikasi ───────────────────────────────────────
NAMA_APLIKASI=Acakehan
VERSI_APLIKASI=1.0.0
MODE_DEBUG=True
# Lingkungan: development / production
LINGKUNGAN=development

# ── Database MySQL ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAMA=db_acakehan
DB_PENGGUNA=root
DB_KATA_SANDI=kata_sandi_anda_di_sini

# Pool koneksi database
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Keamanan JWT ─────────────────────────────────────────────
# Buat kunci acak: python -c "import secrets; print(secrets.token_hex(32))"
JWT_KUNCI_RAHASIA=ganti-dengan-string-acak-64-karakter-yang-tidak-bisa-ditebak
JWT_ALGORITMA=HS256
JWT_JAM_KADALUARSA_AKSES=24
JWT_HARI_KADALUARSA_REFRESH=30

# ── Bcrypt ───────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Anggaran & Notifikasi ────────────────────────────────────
BATAS_PERSEN_PERINGATAN=80.0
BATAS_PERSEN_KRITIS=100.0

# ── CORS (pisahkan dengan koma jika lebih dari satu) ─────────
ASAL_CORS_DIIZINKAN=http://localhost:3000,http://localhost:8080
