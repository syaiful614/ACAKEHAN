# ============================================================
#  .env.example — Template konfigurasi environment Acakehan
#  Salin file ini menjadi ".env" dan isi dengan nilai yang sesuai.
#  JANGAN commit file .env yang asli ke dalam repositori Git!
# ============================================================

# Mode aplikasi: 'pengembangan' atau 'produksi'
FLASK_ENV=pengembangan

# ── Konfigurasi Database MySQL ──────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAMA=db_acakehan
DB_PENGGUNA=root
DB_KATA_SANDI=kata_sandi_database_anda

# ── Konfigurasi JWT ─────────────────────────────────────────
# Ganti dengan string acak yang panjang dan tidak mudah ditebak!
# Bisa dibuat dengan: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=ganti-dengan-kunci-rahasia-sangat-panjang-dan-acak

# Masa berlaku token (dalam satuan jam / hari)
JWT_JAM_AKSES=24
JWT_HARI_REFRESH=30

# ── Konfigurasi Notifikasi ───────────────────────────────────
AKTIFKAN_PUSH_NOTIF=True
FCM_SERVER_KEY=kunci-firebase-cloud-messaging-anda

# ── Konfigurasi Mode Debug ───────────────────────────────────
MODE_DEBUG=True
